# ───── Backend environment template ─────
# Copy to `.env` and fill in real values. NEVER commit the real .env.

# TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# AI / ML embedding service
AI_SERVICE_BASE=http://localhost:5000
AI_SERVICE_KEY=your_ai_service_key_here

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=movieswipe
PG_USER=postgres
PG_PASSWORD=your_db_password_here

# Express server port
PORT=3000
